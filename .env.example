# Claude — uses the Claude Code CLI (your existing subscription login),
# no API key required. Only change CLAUDE_CLI_PATH if `claude` isn't on PATH.
CLAUDE_CLI_PATH=claude
CLAUDE_CLI_TIMEOUT=180

# App paths
CHROMA_DB_PATH=./chroma_db
KNOWLEDGE_BASE_PATH=./knowledge_base/documents
INBOX_PATH=./inbox
PROCESSED_PATH=./processed
OUTPUTS_PATH=./outputs
LOG_LEVEL=INFO
POLICY_VERSION=1.0

# Email (sending is stubbed for now — logs instead of sending)
EMAIL_FROM=dealsense@example.com
EMAIL_FROM_NAME=DealSense AI
